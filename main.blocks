<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="Zz9rvW}}7ch(bm~gLG;7" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="F3Acckd5A3[,k0..7V%-"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum MotorDirection {" line1="    //% block=&quot;forward&quot;" line2="    Forward = 1," line3="    //% block=&quot;backward&quot;" line4="    Backward = 0" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="yYQ:#ie1:J-_{v-aJpg0"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum MotorPin {" line1="    //% block=&quot;P0&quot;" line2="    P0 = AnalogPin.P0," line3="    //% block=&quot;P1&quot;" line4="    P1 = AnalogPin.P1," line5="    //% block=&quot;P2&quot;" line6="    P2 = AnalogPin.P2," line7="    //% block=&quot;P8&quot;" line8="    P8 = AnalogPin.P8," line9="    //% block=&quot;P12&quot;" line10="    P12 = AnalogPin.P12," line11="    //% block=&quot;P16&quot;" line12="    P16 = AnalogPin.P16" line13="}" numlines="14"></mutation><next><block type="typescript_statement" id="mHjdNAcxm[vI94`h*Op6"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace myMotor {" line1="" line2="    let motorSpeed = 255" line3="" line4="    //% block=&quot;set motor speed to %speed&quot;" line5="    //% speed.min=0 speed.max=255 speed.defl=255" line6="    //% speed.shadow=&quot;range&quot;" line7="    export function setSpeed(speed: number): void {" line8="        motorSpeed = speed" line9="    }" line10="" line11="    //% block=&quot;run motor on pin %pin direction %dir&quot;" line12="    //% pin.defl=MotorPin.P0" line13="    //% dir.defl=MotorDirection.Forward" line14="    export function runMotor(pin: MotorPin, dir: MotorDirection): void {" line15="        let pwm = Math.map(motorSpeed, 0, 255, 0, 1023)" line16="        pins.analogWritePin(pin as number, dir === MotorDirection.Forward ? pwm : 1023 - pwm)" line17="    }" line18="" line19="    //% block=&quot;run motor on pin %pin direction %dir speed %speed&quot;" line20="    //% speed.min=0 speed.max=255 speed.defl=255" line21="    //% pin.defl=MotorPin.P0" line22="    //% dir.defl=MotorDirection.Forward" line23="    export function runMotorSpeed(pin: MotorPin, dir: MotorDirection, speed: number): void {" line24="        let pwm2 = Math.map(speed, 0, 255, 0, 1023)" line25="        pins.analogWritePin(pin as number, dir === MotorDirection.Forward ? pwm2 : 1023 - pwm2)" line26="    }" line27="" line28="    //% block=&quot;stop motor on pin %pin&quot;" line29="    //% pin.defl=MotorPin.P0" line30="    export function stopMotor(pin: MotorPin): void {" line31="        pins.analogWritePin(pin as number, 0)" line32="    }" line33="}" numlines="34"></mutation></block></next></block></next></block></statement></block></xml>